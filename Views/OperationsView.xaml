<UserControl x:Class="WarehouseAccountingApp.Views.OperationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Приход -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Приход товара"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="{StaticResource GreenTextBrush}"
                           Margin="0,0,0,16"/>

                <TextBlock Grid.Row="1" Text="Товар" Margin="0,0,0,4"/>
                <ComboBox  Grid.Row="2" x:Name="InProductBox" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="3" Text="Поставщик" Margin="0,0,0,4"/>
                <ComboBox  Grid.Row="4" x:Name="SupplierBox" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="5" Text="Количество" Margin="0,0,0,4"/>
                <TextBox   Grid.Row="6" x:Name="InQuantityBox" Text="1" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="7" Text="Комментарий" Margin="0,0,0,4"/>
                <TextBox   Grid.Row="8" x:Name="InCommentBox"
                           Height="80" TextWrapping="Wrap"
                           AcceptsReturn="True" VerticalContentAlignment="Top"
                           Margin="0,0,0,20"/>

                <Button Grid.Row="9" Content="+ Оформить приход"
                        Style="{StaticResource SuccessButtonStyle}"
                        Height="44" Click="StockIn_Click"/>
            </Grid>
        </Border>

        <!-- Расход -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Расход товара"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="{StaticResource RedTextBrush}"
                           Margin="0,0,0,16"/>

                <TextBlock Grid.Row="1" Text="Товар" Margin="0,0,0,4"/>
                <ComboBox  Grid.Row="2" x:Name="OutProductBox" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="3" Text="Причина списания" Margin="0,0,0,4"/>
                <ComboBox  Grid.Row="4" x:Name="ReasonBox" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="5" Text="Количество" Margin="0,0,0,4"/>
                <TextBox   Grid.Row="6" x:Name="OutQuantityBox" Text="1" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="7" Text="Комментарий" Margin="0,0,0,4"/>
                <TextBox   Grid.Row="8" x:Name="OutCommentBox"
                           Height="80" TextWrapping="Wrap"
                           AcceptsReturn="True" VerticalContentAlignment="Top"
                           Margin="0,0,0,20"/>

                <Button Grid.Row="9" Content="− Оформить расход"
                        Style="{StaticResource DangerButtonStyle}"
                        Height="44" Click="StockOut_Click"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
