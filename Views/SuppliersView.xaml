<UserControl x:Class="WarehouseAccountingApp.Views.SuppliersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="Поставщики" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,16"/>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Grid.Column="0" Margin="0,0,10,0"
                         TextChanged="SearchBox_TextChanged"/>
                <Button x:Name="AddButton" Grid.Column="1" Content="Добавить"
                        Style="{StaticResource PrimaryButtonStyle}" Click="AddButton_Click"/>
            </Grid>
        </StackPanel>
        <DataGrid x:Name="SuppliersGrid"/>
    </DockPanel>
</UserControl>
